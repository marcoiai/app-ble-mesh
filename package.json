{
  "name": "app-ble-mesh",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "exports": {
    "./mesh-core": {
      "types": "./dist/mesh-core/index.d.ts",
      "import": "./dist/mesh-core/index.js"
    },
    "./mesh-core/*": {
      "types": "./dist/mesh-core/*.d.ts",
      "import": "./dist/mesh-core/*.js"
    }
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build && pnpm build:mesh-core",
    "build:mesh-core": "tsc -p tsconfig.mesh-core.json",
    "preview": "vite preview",
    "tauri": "tauri"
  },
  "dependencies": {
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-opener": "^2"
  },
  "devDependencies": {
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.6.0",
    "typescript": "~5.8.3",
    "vite": "^7.0.4",
    "@tauri-apps/cli": "^2"
  }
}
